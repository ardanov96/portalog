generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  STAFF
  CLIENT
}

enum ShipmentType {
  EXPORT
  IMPORT
}

enum ShipmentMode {
  SEA_FCL
  SEA_LCL
  AIR
  LAND
}

enum ShipmentStatus {
  DRAFT
  BOOKING_CONFIRMED
  DOCS_IN_PROGRESS
  CUSTOMS_PROCESSING
  CARGO_RELEASED
  IN_TRANSIT
  ARRIVED
  DELIVERED
  COMPLETED
  CANCELLED
}

enum DocumentType {
  BILL_OF_LADING
  AIRWAY_BILL
  COMMERCIAL_INVOICE
  PACKING_LIST
  CERTIFICATE_OF_ORIGIN
  PIB
  PEB
  CUSTOMS_RELEASE
  INSURANCE_POLICY
  OTHER
}

enum DocumentStatus {
  PENDING
  UPLOADED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum SubscriptionPlan {
  TRIAL
  STARTER
  GROWTH
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum DashboardMode {
  FORWARDER
  EXPORTER
  IMPORTER
}

model Organization {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  npwp          String?
  phone         String?
  email         String?
  address       String?
  city          String?
  logoUrl       String?
  timezone      String        @default("Asia/Jakarta")
  dashboardMode DashboardMode @default(FORWARDER)
  apiKeys       ApiKey[]

  // Referral program
  referralCode   String?  @unique  // kode unik org ini untuk mengajak org lain
  referralCredits Int     @default(0)  // kredit dalam bulan (belum diklaim)
  referralUsedAt  DateTime?           // kapan kredit terakhir diklaim

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  users        User[]
  clients      Client[]
  shipments    Shipment[]
  subscription Subscription?
  staffInvites StaffInvite[]
  referrals    Referral[]    @relation("ReferrerOrg")
  referredBy   Referral[]    @relation("ReferredOrg")
  whiteLabel   WhiteLabel?

  @@map("organizations")
}

model Subscription {
  id             String             @id @default(cuid())
  organizationId String             @unique
  plan           SubscriptionPlan   @default(TRIAL)
  status         SubscriptionStatus @default(TRIALING)
  trialEndsAt    DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean        @default(false)

  // Midtrans fields
  midtransCustomerId  String?
  midtransSubsId      String?
  lastOrderId         String?
  lastPaymentType     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  billingHistory BillingHistory[]

  @@map("subscriptions")
}

model BillingHistory {
  id             String   @id @default(cuid())
  subscriptionId String
  orderId        String   @unique
  amount         Int
  status         String   // settlement, pending, cancel, expire, deny
  paymentType    String?
  description    String?
  paidAt         DateTime?
  createdAt      DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("billing_history")
}

model StaffInvite {
  id             String    @id @default(cuid())
  organizationId String
  email          String
  name           String?
  role           UserRole  @default(STAFF)
  token          String    @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  invitedById    String?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([organizationId, email])
  @@map("staff_invites")
}

model User {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  email          String    @unique
  passwordHash   String
  role           UserRole  @default(STAFF)
  phone          String?
  avatarUrl      String?
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization      Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedShipments Shipment[]    @relation("AssignedTo")
  activityLogs      ActivityLog[]
  notifications     Notification[]

  @@map("users")
}

model Client {
  id                 String   @id @default(cuid())
  organizationId     String
  name               String
  companyName        String?
  npwp               String?
  email              String?
  phone              String?
  address            String?
  city               String?
  country            String   @default("ID")
  notes              String?
  isActive           Boolean  @default(true)
  portalEmail        String?
  portalPasswordHash String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shipments    Shipment[]

  @@map("clients")
}

model Shipment {
  id             String         @id @default(cuid())
  organizationId String
  clientId       String
  assignedToId   String?
  referenceNo    String         @unique
  type           ShipmentType
  mode           ShipmentMode
  status         ShipmentStatus @default(DRAFT)

  originCountry      String?
  originPort         String?
  destinationCountry String?
  destinationPort    String?

  cargoDescription String?
  grossWeight      Float?
  volume           Float?
  packageCount     Int?
  hsCode           String?

  vesselName String?
  voyageNo   String?
  imoNumber  String?     // IMO vessel identifier untuk tracking akurat
  mmsiNumber String?     // MMSI untuk AIS tracking
  etd        DateTime?
  eta        DateTime?
  etaUpdatedAt DateTime? // Kapan ETA terakhir diperbarui dari vessel data
  atd        DateTime?
  ata        DateTime?

  // Vessel position cache (diupdate oleh cron)
  vesselLat        Float?
  vesselLon        Float?
  vesselSpeed      Float?   // knots
  vesselCourse     Float?   // degrees
  vesselStatus     String?  // "underway", "at anchor", "moored", dll
  vesselPositionAt DateTime? // timestamp posisi terakhir

  pibNo           String?
  pebNo           String?
  customsDeadline DateTime?

  freightCost  Float?
  localCharges Float?
  customsDuty  Float?
  totalCost    Float?
  invoiceNo    String?
  invoiceDate  DateTime?
  isPaid       Boolean  @default(false)

  notes         String?
  internalNotes String?

  // AI Delay Prediction cache (diupdate on-demand, max sekali per 6 jam)
  delayRiskScore    Int?      // 0-100
  delayRiskLevel    String?   // "low" | "medium" | "high" | "critical"
  delayRiskFactors  String?   // JSON array of risk factors
  delayRiskSummary  String?   // Ringkasan teks
  delayPredictedAt  DateTime? // Kapan prediksi terakhir dibuat

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client         Client                 @relation(fields: [clientId], references: [id])
  assignedTo     User?                  @relation("AssignedTo", fields: [assignedToId], references: [id])
  documents      Document[]
  statusHistory  ShipmentStatusHistory[]
  activityLogs   ActivityLog[]
  notifications  Notification[]

  @@index([organizationId, status])
  @@index([organizationId, clientId])
  @@map("shipments")
}

model ShipmentStatusHistory {
  id          String         @id @default(cuid())
  shipmentId  String
  fromStatus  ShipmentStatus?
  toStatus    ShipmentStatus
  note        String?
  changedById String?
  changedAt   DateTime       @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@map("shipment_status_history")
}

model Document {
  id                String         @id @default(cuid())
  shipmentId        String
  type              DocumentType
  status            DocumentStatus @default(PENDING)
  name              String
  fileUrl           String?
  fileSize          Int?
  mimeType          String?
  version           Int            @default(1)
  notes             String?
  isRequired        Boolean        @default(true)
  isVisibleToClient Boolean        @default(false)
  uploadedById      String?
  approvedById      String?
  approvedAt        DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@map("documents")
}

model ActivityLog {
  id          String   @id @default(cuid())
  shipmentId  String?
  userId      String?
  action      String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  shipment Shipment? @relation(fields: [shipmentId], references: [id], onDelete: SetNull)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([shipmentId])
  @@map("activity_logs")
}

model Notification {
  id           String   @id @default(cuid())
  userId       String?
  shipmentId   String?
  type         String
  title        String
  message      String
  isRead       Boolean  @default(false)
  sentViaEmail Boolean  @default(false)
  sentViaWa    Boolean  @default(false)
  createdAt    DateTime @default(now())

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  shipment Shipment? @relation(fields: [shipmentId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@map("notifications")
}

// ─── Referral Program ─────────────────────────────────────────────────────────

enum ReferralStatus {
  PENDING    // Referral dibuat, org yg dirujuk belum subscribe
  QUALIFIED  // Org yg dirujuk sudah subscribe (paid)
  REWARDED   // Reward sudah diklaim/diterapkan ke referrer
  EXPIRED    // Referral hangus (org yg dirujuk tidak convert dalam 90 hari)
}

model Referral {
  id               String         @id @default(cuid())
  referrerOrgId    String         // Org yang memberi kode
  referredOrgId    String?        // Org yang mendaftar pakai kode (null jika belum daftar)
  code             String         // Kode referral yang digunakan
  status           ReferralStatus @default(PENDING)
  rewardMonths     Int            @default(1)    // Berapa bulan kredit reward
  rewardAppliedAt  DateTime?      // Kapan kredit diterapkan
  referredEmail    String?        // Email org yg diundang (opsional, untuk tracking)
  referredOrgName  String?        // Nama org yg mendaftar
  qualifiedAt      DateTime?      // Kapan org referral subscribe pertama
  expiresAt        DateTime       // 90 hari dari waktu kode dibuat
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  referrerOrg Organization  @relation("ReferrerOrg", fields: [referrerOrgId], references: [id], onDelete: Cascade)
  referredOrg  Organization? @relation("ReferredOrg",  fields: [referredOrgId],  references: [id], onDelete: SetNull)

  @@index([code])
  @@index([referrerOrgId, status])
  @@map("referrals")
}

// ─── White-label ──────────────────────────────────────────────────────────────

enum WhiteLabelStatus {
  PENDING     // Domain belum diverifikasi
  ACTIVE      // Domain aktif & terverifikasi
  SUSPENDED   // Dinonaktifkan oleh admin
}

model WhiteLabel {
  id             String            @id @default(cuid())
  organizationId String            @unique
  status         WhiteLabelStatus  @default(PENDING)

  // Custom domain
  customDomain      String?  @unique  // e.g. "portal.majulogistik.co.id"
  domainVerifiedAt  DateTime?
  domainVerifyToken String?  @unique  // TXT record untuk verifikasi DNS

  // Branding
  brandName        String?          // Nama brand (default: org name)
  logoUrl          String?          // URL logo (override org logo)
  faviconUrl       String?
  primaryColor     String?          // Hex: "1A3C34"
  accentColor      String?          // Hex: "C8953A"
  fontFamily       String?          // "Inter", "Plus Jakarta Sans", dll
  backgroundStyle  String           @default("solid")  // "solid" | "gradient"
  backgroundColor  String?          // Hex

  // Portal text
  portalTitle      String?          // Judul halaman portal
  portalWelcome    String?          // Pesan selamat datang
  portalFooter     String?          // Teks footer kustom
  supportEmail     String?
  supportPhone     String?
  supportWhatsapp  String?

  // Feature flags untuk portal klien white-label
  showPoweredBy    Boolean  @default(true)   // "Powered by Portalog"
  showChatbot      Boolean  @default(true)
  showDocuments    Boolean  @default(true)
  showTimeline     Boolean  @default(true)
  allowClientLogin Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("white_labels")
}

model ApiKey {
  id             String        @id @default(cuid())
  organizationId String
  name           String
  keyHash        String        @unique
  keyPrefix      String
  scopes         ApiKeyScope[]
  isActive       Boolean       @default(true)
  lastUsedAt     DateTime?
  lastUsedIp     String?
  expiresAt      DateTime?
  requestCount   BigInt        @default(0)
  monthlyCount   Int           @default(0)
  monthlyLimit   Int           @default(10000)
  description    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  logs         ApiKeyLog[]

  @@index([organizationId, isActive])
  @@map("api_keys")
}

enum ApiKeyScope {
  SHIPMENTS_READ
  SHIPMENTS_WRITE
  CLIENTS_READ
  CLIENTS_WRITE
  DOCUMENTS_READ
  DOCUMENTS_WRITE
  INVOICES_READ
  ANALYTICS_READ
  ALL_READ
  ALL_WRITE
}

model ApiKeyLog {
  id         String   @id @default(cuid())
  apiKeyId   String
  endpoint   String
  method     String
  status     Int
  ipAddress  String?
  userAgent  String?
  durationMs Int?
  createdAt  DateTime @default(now())

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId, createdAt])
  @@map("api_key_logs")
}
